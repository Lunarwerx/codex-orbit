# SayDeploy-managed .gitignore — keeps secrets and build artifacts out of git
.env
.env.*
*.env
credentials.toml
credentials.toml.enc
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.keystore
.secrets
secrets/
config/secrets.yml
config/secrets.yaml
config/database.yml
config/master.key
node_modules/
__pycache__/
*.pyc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
.next/
.nuxt/
out/
!stable/codex_assets/out/
!stable/codex_assets/out/extension.js
*.vsix
# ...but DO keep the numbered wrapper builds + the build log visible. The build
# NUMBER in the filename is how we know a build actually happened and which is
# newest. (The huge upstream Codex .vsix files stay ignored.)
!builds/codex-orbit-build-*.vsix
!builds/BUILD_LOG.md
!latest/codex-orbit.vsix
.tmp/
.DS_Store
Thumbs.db
.vscode/settings.json
.vscode/paramount.json
.idea/
*.log
logs/
